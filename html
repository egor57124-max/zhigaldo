<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Воздушный хоккей — Три кота</title>
    <style>
        * {
            user-select: none;
            touch-action: none; /* Отключаем прокрутку страницы при касании canvas */
            -webkit-tap-highlight-color: transparent;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background: linear-gradient(145deg, #1a472a 0%, #0e2a1a 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', 'Comic Neue', 'Comic Sans MS', 'Chalkboard SE', cursive, sans-serif;
            touch-action: none;
        }

        .game-container {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 12px;
        }

        canvas {
            display: block;
            margin: 0 auto;
            border-radius: 48px;
            box-shadow: 0 20px 35px rgba(0,0,0,0.4), inset 0 0 0 2px rgba(255,215,150,0.6);
            cursor: none;
            background: #2b5e3b;
            width: 100%;
            height: auto;
        }

        /* Панель счета и кнопка рестарта */
        .score-panel {
            position: absolute;
            top: 20px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            pointer-events: none;
            z-index: 10;
        }

        .score-card {
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(8px);
            border-radius: 60px;
            padding: 8px 20px;
            color: #FFE5A3;
            font-weight: bold;
            font-size: 1.5rem;
            text-shadow: 2px 2px 0 #b45f1b;
            letter-spacing: 1px;
            border: 1px solid rgba(255,215,0,0.5);
            box-shadow: 0 5px 10px rgba(0,0,0,0.3);
            font-family: inherit;
            pointer-events: auto;
        }

        .score-card span {
            font-size: 1.8rem;
            color: #ffcc66;
            margin-right: 5px;
        }

        .reset-btn {
            background: #ff9f4a;
            border: none;
            font-size: 1.3rem;
            font-weight: bold;
            font-family: inherit;
            color: #2d2b1f;
            padding: 8px 20px;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 5px 0 #9b4a1a;
            transition: 0.07s linear;
            pointer-events: auto;
            touch-action: manipulation;
            backdrop-filter: blur(4px);
        }

        .reset-btn:active {
            transform: translateY(3px);
            box-shadow: 0 2px 0 #9b4a1a;
        }

        /* Инструкция для мобильных */
        .mobile-hint {
            position: absolute;
            bottom: 15px;
            left: 0;
            right: 0;
            text-align: center;
            color: #f9e0a0;
            background: rgba(0,0,0,0.5);
            border-radius: 30px;
            width: fit-content;
            margin: 0 auto;
            padding: 5px 15px;
            font-size: 0.7rem;
            font-weight: bold;
            backdrop-filter: blur(4px);
            pointer-events: none;
            white-space: nowrap;
            font-family: monospace;
        }

        @media (max-width: 600px) {
            .score-card { padding: 4px 15px; font-size: 1.2rem; }
            .score-card span { font-size: 1.5rem; }
            .reset-btn { padding: 5px 15px; font-size: 1.1rem; }
        }
    </style>
</head>
<body>
<div class="game-container">
    <canvas id="gameCanvas" width="900" height="600"></canvas>
    <div class="score-panel">
        <div class="score-card"><span>🐱</span> Котята: <span id="playerScore">0</span></div>
        <div class="score-card"><span>😾</span> Коржик-комп: <span id="aiScore">0</span></div>
        <button class="reset-btn" id="resetGameBtn">✨ Новая игра ✨</button>
    </div>
    <div class="mobile-hint">👆 Ведите пальцем по экрану — двигайте ракетку! 🏒</div>
</div>

<script>
    (function(){
        // ---------- ИГРОВЫЕ ПАРАМЕТРЫ ----------
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');

        // Размеры поля (внутренние отступы для красоты)
        let board = {
            width: 900,
            height: 600,
            leftWall: 20,
            rightWall: 880,
            topWall: 40,
            bottomWall: 560
        };

        // Шайба
        let puck = {
            x: board.width/2,
            y: board.height/2,
            radius: 12,
            vx: 2.4,
            vy: 1.8,
            maxSpeed: 7.2
        };

        // Ракетка игрока (три кота) — управление пальцем/мышью
        let playerPaddle = {
            x: board.width/2,
            y: board.bottomWall - 30,
            width: 70,
            height: 18,
            radius: 14
        };

        // Ракетка AI (Коржик-компьютер)
        let aiPaddle = {
            x: board.width/2,
            y: board.topWall + 15,
            width: 70,
            height: 18,
            radius: 14
        };

        // Счет
        let playerScore = 0;
        let aiScore = 0;
        const WIN_SCORE = 7;   // Победа при 7 очках

        let gameActive = true;
        let winnerMessage = null; // "Котята победили!" или "Коржик победил..."

        // Для мобильного управления
        let touchActive = false;

        // Настройка сложности AI (чувствительность)
        const AI_SPEED_FACTOR = 0.09;
        const AI_MARGIN = 12;

        // ---------- ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ----------
        function clamp(value, min, max) {
            return Math.min(max, Math.max(min, value));
        }

        // Сброс игры (сохраняем счет, если нужно, но для новой игры обнуляем всё)
        function resetGame() {
            playerScore = 0;
            aiScore = 0;
            gameActive = true;
            winnerMessage = null;
            resetPuck();
            // ракетки ставим по центру
            playerPaddle.x = board.width/2;
            aiPaddle.x = board.width/2;
            updateScoreUI();
        }

        // Сброс позиции шайбы после гола
        function resetPuck() {
            puck.x = board.width/2;
            puck.y = board.height/2;
            // Случайное направление после гола, но не строго вертикально
            let angle = (Math.random() * Math.PI * 2);
            let speed = 3.2;
            puck.vx = Math.cos(angle) * speed;
            puck.vy = Math.sin(angle) * speed;
            // Небольшая корректировка, чтобы не было слишком полого
            if(Math.abs(puck.vx) < 1.2) puck.vx = puck.vx > 0 ? 1.5 : -1.5;
            if(Math.abs(puck.vy) < 1.2) puck.vy = puck.vy > 0 ? 1.8 : -1.8;
            // Ограничение скорости
            let mag = Math.hypot(puck.vx, puck.vy);
            if(mag > puck.maxSpeed) {
                puck.vx = (puck.vx / mag) * puck.maxSpeed;
                puck.vy = (puck.vy / mag) * puck.maxSpeed;
            }
            // дополнительная задержка перед движением не требуется, просто даем старт
        }

        // Обновление UI счета
        function updateScoreUI() {
            document.getElementById('playerScore').innerText = playerScore;
            document.getElementById('aiScore').innerText = aiScore;
        }

        // Проверка победы
        function checkWin() {
            if(!gameActive) return true;
            if(playerScore >= WIN_SCORE) {
                gameActive = false;
                winnerMessage = "🐱🏆 Котята победили! 🎉🏆";
                return true;
            }
            if(aiScore >= WIN_SCORE) {
                gameActive = false;
                winnerMessage = "😾 Коржик победил... Попробуй ещё! 😾";
                return true;
            }
            return false;
        }

        // Столкновение шайбы с ракеткой (упрощённое эластичное + придание эффекта)
        function collideWithPaddle(paddle, isPlayer) {
            // Прямоугольное столкновение с округлением
            let closestX = clamp(puck.x, paddle.x - paddle.width/2, paddle.x + paddle.width/2);
            let closestY = clamp(puck.y, paddle.y - paddle.height/2, paddle.y + paddle.height/2);
            let dx = puck.x - closestX;
            let dy = puck.y - closestY;
            let dist = Math.hypot(dx, dy);
            if(dist < puck.radius + paddle.radius) {
                // нормаль отскока
                let angle = Math.atan2(dy, dx);
                let speed = Math.hypot(puck.vx, puck.vy);
                let newVx = Math.cos(angle) * speed;
                let newVy = Math.sin(angle) * speed;
                // Увеличиваем скорость чуть-чуть для динамики, но не выше maxSpeed
                let boost = 1.05;
                puck.vx = newVx * boost;
                puck.vy = newVy * boost;

                // Добавляем "подкрутку" в зависимости от того, куда ударила ракетка (эффект удара)
                let hitPos = (puck.x - paddle.x) / (paddle.width/2);
                hitPos = clamp(hitPos, -0.9, 0.9);
                if(isPlayer) {
                    puck.vx += hitPos * 1.6;
                } else {
                    puck.vx += hitPos * 1.4;
                }

                // Ограничиваем скорость
                let newMag = Math.hypot(puck.vx, puck.vy);
                if(newMag > puck.maxSpeed) {
                    puck.vx = (puck.vx / newMag) * puck.maxSpeed;
                    puck.vy = (puck.vy / newMag) * puck.maxSpeed;
                }
                if(newMag < 2.0 && (Math.abs(puck.vx) + Math.abs(puck.vy) > 0.1)) {
                    // не даем шайбе слишком замедляться
                    puck.vx *= 1.1;
                    puck.vy *= 1.1;
                }

                // выталкивание шайбы чтобы не застревала
                let overlap = puck.radius + paddle.radius - dist;
                let pushX = (dx / dist) * overlap;
                let pushY = (dy / dist) * overlap;
                puck.x += pushX;
                puck.y += pushY;

                // Звуковой эффект (писк — через web audio, но не навязчиво)
                playPuckSound();
                return true;
            }
            return false;
        }

        // Простой звуковой щелчок (опционально, без лишних разрешений)
        let audioCtx = null;
        function playPuckSound() {
            try {
                if (!audioCtx) {
                    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                }
                // Не создаем тысячи звуков каждые 10мс, но в игре частота столкновений ~ раз в кадр норм
                const now = audioCtx.currentTime;
                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.connect(gain);
                gain.connect(audioCtx.destination);
                osc.type = 'sine';
                osc.frequency.value = 880;
                gain.gain.value = 0.12;
                osc.start();
                gain.gain.exponentialRampToValueAtTime(0.00001, now + 0.12);
                osc.stop(now + 0.12);
            } catch(e) { /* тишина если авто-политика */ }
        }

        // Движение и коллизии со стенами (шайба)
        function updatePuck() {
            if(!gameActive) return;

            puck.x += puck.vx;
            puck.y += puck.vy;

            // Стены: лево/право
            if(puck.x - puck.radius <= board.leftWall) {
                puck.x = board.leftWall + puck.radius;
                puck.vx = -puck.vx;
                playPuckSound();
            }
            if(puck.x + puck.radius >= board.rightWall) {
                puck.x = board.rightWall - puck.radius;
                puck.vx = -puck.vx;
                playPuckSound();
            }

            // ГОЛЫ: верхняя стена (зона AI) и нижняя стена (зона игрока)
            // Гол в ворота игрока (шайба коснулась верхней стенки, но только в пределах ворот)
            if(puck.y - puck.radius <= board.topWall) {
                // Это гол компьютера (AI забивает)
                if(puck.x > board.width*0.25 && puck.x < board.width*0.75) {
                    aiScore++;
                    updateScoreUI();
                    resetPuck();
                    checkWin();
                    playPuckSound();
                } else {
                    // обычный отскок от верхней стенки (угол)
                    puck.y = board.topWall + puck.radius;
                    puck.vy = -puck.vy;
                    playPuckSound();
                }
            }
            // Гол в ворота AI (шайба коснулась нижней стенки)
            if(puck.y + puck.radius >= board.bottomWall) {
                if(puck.x > board.width*0.25 && puck.x < board.width*0.75) {
                    playerScore++;
                    updateScoreUI();
                    resetPuck();
                    checkWin();
                    playPuckSound();
                } else {
                    puck.y = board.bottomWall - puck.radius;
                    puck.vy = -puck.vy;
                    playPuckSound();
                }
            }

            // Боковые отскоки от верхней и нижней зоны вне ворот (уже частично обработано)
            // дополнительная защита от вылета за пределы:
            puck.x = clamp(puck.x, board.leftWall + puck.radius, board.rightWall - puck.radius);
            puck.y = clamp(puck.y, board.topWall + puck.radius, board.bottomWall - puck.radius);
        }

        // Движение AI (Коржик) — умное слежение за шайбой с плавностью
        function updateAI() {
            if(!gameActive) return;
            let targetX = puck.x;
            // AI чуть предсказывает движение если шайба летит в его сторону
            let prediction = 0;
            if(puck.vy < 0 && puck.y < board.height/2) {
                prediction = puck.vx * 0.55;
            }
            let desiredX = targetX + prediction;
            desiredX = clamp(desiredX, board.leftWall + aiPaddle.width/2, board.rightWall - aiPaddle.width/2);
            let diff = desiredX - aiPaddle.x;
            let move = diff * AI_SPEED_FACTOR;
            if(Math.abs(diff) > 3) move = Math.min(Math.max(move, -6.5), 6.5);
            aiPaddle.x += move;
            aiPaddle.x = clamp(aiPaddle.x, board.leftWall + aiPaddle.width/2, board.rightWall - aiPaddle.width/2);
        }

        // Обновление позиции ракетки игрока (сенсорное / мышь)
        function updatePlayerPaddleFromCoord(clientX, clientY) {
            if(!gameActive) return;
            const rect = canvas.getBoundingClientRect();
            const scaleX = canvas.width / rect.width;
            const scaleY = canvas.height / rect.height;
            let canvasX = (clientX - rect.left) * scaleX;
            canvasX = clamp(canvasX, board.leftWall + playerPaddle.width/2, board.rightWall - playerPaddle.width/2);
            playerPaddle.x = canvasX;
        }

        // Столкновения ракеток с шайбой (проверка в каждом кадре)
        function handleCollisions() {
            if(!gameActive) return;
            collideWithPaddle(playerPaddle, true);
            collideWithPaddle(aiPaddle, false);
        }

        // ---------- ОТРИСОВКА ВСЕХ ЭЛЕМЕНТОВ (ТРИ КОТА!) ----------
        function drawField() {
            // Ледовая арена с градиентом
            const grad = ctx.createLinearGradient(0,0,0,board.height);
            grad.addColorStop(0, '#70c8a0');
            grad.addColorStop(1, '#3f9e6b');
            ctx.fillStyle = grad;
            ctx.fillRect(0,0,board.width,board.height);
            // Разметка
            ctx.strokeStyle = '#FFF7CF';
            ctx.lineWidth = 3;
            ctx.setLineDash([12, 18]);
            ctx.beginPath();
            ctx.moveTo(board.width/2, board.topWall);
            ctx.lineTo(board.width/2, board.bottomWall);
            ctx.stroke();
            ctx.setLineDash([]);
            // Центральный круг
            ctx.beginPath();
            ctx.arc(board.width/2, board.height/2, 55, 0, Math.PI*2);
            ctx.strokeStyle = '#FFE3A3';
            ctx.lineWidth = 3;
            ctx.stroke();
            ctx.beginPath();
            ctx.arc(board.width/2, board.height/2, 22, 0, Math.PI*2);
            ctx.fillStyle = '#F9E0A0';
            ctx.fill();
            // Ворота (золотые дуги)
            ctx.fillStyle = '#CDAA76';
            ctx.shadowBlur = 0;
            // Нижние ворота (игрок)
            ctx.fillRect(board.width*0.25, board.bottomWall-8, board.width*0.5, 8);
            ctx.fillStyle = '#E5C28E';
            ctx.fillRect(board.width*0.26, board.bottomWall-5, board.width*0.48, 5);
            // Верхние ворота
            ctx.fillStyle = '#CDAA76';
            ctx.fillRect(board.width*0.25, board.topWall, board.width*0.5, 8);
            ctx.fillStyle = '#E5C28E';
            ctx.fillRect(board.width*0.26, board.topWall+1, board.width*0.48, 5);
        }

        function drawPaddle(paddle, isPlayer) {
            // Рисуем ракетку с персонажами "Три кота"
            ctx.save();
            ctx.shadowBlur = 6;
            ctx.shadowColor = "rgba(0,0,0,0.3)";
            ctx.fillStyle = isPlayer ? '#F2B84E' : '#51A0D5';
            ctx.beginPath();
            ctx.roundRect(paddle.x - paddle.width/2, paddle.y - paddle.height/2, paddle.width, paddle.height, 12);
            ctx.fill();
            ctx.fillStyle = isPlayer ? '#FFD966' : '#7AC4F0';
            ctx.beginPath();
            ctx.roundRect(paddle.x - paddle.width/2 + 3, paddle.y - paddle.height/2 + 2, paddle.width-6, paddle.height-4, 8);
            ctx.fill();
            // Рисуем мордочки котят!
            ctx.font = `${paddle.height * 1.3}px "Segoe UI Emoji"`;
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            if(isPlayer) {
                ctx.fillStyle = "#3F2A1C";
                ctx.fillText("🐱", paddle.x, paddle.y+1);
                ctx.fillStyle = "#F7B05E";
                ctx.fillText("🐱", paddle.x-12, paddle.y-2);
                ctx.fillText("🐱", paddle.x+13, paddle.y-2);
            } else {
                ctx.fillStyle = "#2C2C3A";
                ctx.fillText("😺", paddle.x, paddle.y+2);
                ctx.fillText("🧡", paddle.x-8, paddle.y-3);
                ctx.fillText("💙", paddle.x+10, paddle.y-3);
            }
            ctx.restore();
        }

        function drawPuck() {
            ctx.save();
            ctx.shadowBlur = 8;
            ctx.shadowColor = "black";
            ctx.beginPath();
            ctx.arc(puck.x, puck.y, puck.radius, 0, Math.PI*2);
            ctx.fillStyle = "#2B2D2F";
            ctx.fill();
            ctx.beginPath();
            ctx.arc(puck.x, puck.y, puck.radius-2, 0, Math.PI*2);
            ctx.fillStyle = "#E85D04";
            ctx.fill();
            ctx.fillStyle = "white";
            ctx.font = "bold 16px monospace";
            ctx.fillText("⚡", puck.x-5, puck.y+5);
            ctx.restore();
        }

        function drawWinMessage() {
            if(winnerMessage && !gameActive) {
                ctx.font = "bold 32px 'Comic Neue', cursive";
                ctx.fillStyle = "#FFF5CF";
                ctx.shadowBlur = 8;
                ctx.shadowColor = "#3B2A1F";
                ctx.textAlign = "center";
                ctx.fillText(winnerMessage, board.width/2, board.height/2 - 50);
                ctx.font = "24px monospace";
                ctx.fillStyle = "#FFE2A4";
                ctx.fillText("Нажми «Новая игра»", board.width/2, board.height/2 + 30);
                ctx.textAlign = "left";
            }
        }

        // функция roundRect (полифилл)
        if (!CanvasRenderingContext2D.prototype.roundRect) {
            CanvasRenderingContext2D.prototype.roundRect = function(x, y, w, h, r) {
                if (w < 2 * r) r = w / 2;
                if (h < 2 * r) r = h / 2;
                this.moveTo(x+r, y);
                this.lineTo(x+w-r, y);
                this.quadraticCurveTo(x+w, y, x+w, y+r);
                this.lineTo(x+w, y+h-r);
                this.quadraticCurveTo(x+w, y+h, x+w-r, y+h);
                this.lineTo(x+r, y+h);
                this.quadraticCurveTo(x, y+h, x, y+h-r);
                this.lineTo(x, y+r);
                this.quadraticCurveTo(x, y, x+r, y);
                return this;
            };
        }

        function draw() {
            drawField();
            drawPaddle(aiPaddle, false);
            drawPaddle(playerPaddle, true);
            drawPuck();
            drawWinMessage();
        }

        // ---------- АНИМАЦИОННЫЙ ЦИКЛ ----------
        function gameLoop() {
            if(gameActive) {
                updateAI();
                updatePuck();
                handleCollisions();
            }
            draw();
            requestAnimationFrame(gameLoop);
        }

        // ---------- НАСТРОЙКА СОБЫТИЙ (МОБИЛЬНЫЙ ТАЧ + МЫШЬ) ----------
        function attachEvents() {
            // Сенсорное управление (пальцем)
            canvas.addEventListener('touchmove', (e) => {
                e.preventDefault();
                if(!gameActive) return;
                const touch = e.touches[0];
                if(touch) updatePlayerPaddleFromCoord(touch.clientX, touch.clientY);
            }, { passive: false });
            canvas.addEventListener('touchstart', (e) => {
                e.preventDefault();
                const touch = e.touches[0];
                if(touch) updatePlayerPaddleFromCoord(touch.clientX, touch.clientY);
            });
            // Мышь для ПК (для тестирования)
            canvas.addEventListener('mousemove', (e) => {
                if(!gameActive) return;
                updatePlayerPaddleFromCoord(e.clientX, e.clientY);
            });
            canvas.addEventListener('mousedown', (e) => {
                e.preventDefault();
                updatePlayerPaddleFromCoord(e.clientX, e.clientY);
            });
            // Кнопка рестарта
            const resetBtn = document.getElementById('resetGameBtn');
            resetBtn.addEventListener('click', () => {
                resetGame();
                updateScoreUI();
            });
            resetBtn.addEventListener('touchstart', (e) => {
                e.preventDefault();
                resetGame();
                updateScoreUI();
            });
        }

        // Инициализация и старт
        function init() {
            attachEvents();
            resetGame();
            gameLoop();
            // адаптив canvas к мобильному экрану (CSS масштабирование)
            canvas.style.width = '100%';
            canvas.style.height = 'auto';
        }
        init();
    })();
</script>
</body>
</html>
